# PostgreSQL 연결 문자열 (docker-compose 기준)
DATABASE_URL=postgres://devgraph:devgraph@localhost:5432/devgraph

# 단일 관리자 비밀번호 (로그인에 사용)
ADMIN_PASSWORD=devgraph-admin

# 세션 쿠키 서명 키 (아무 긴 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# LLM 추출 프로바이더: codex(로컬 Codex CLI, ChatGPT 구독 사용·API 키 불필요) | openai(API 키)
LLM_PROVIDER=codex
# codex 경로: PATH에 codex가 있으면 그대로 두고, 아니면 절대경로 지정. `codex login`(ChatGPT) 필요.
CODEX_BIN=codex
# CODEX_MODEL=          # 비우면 Codex 기본 모델

# LLM_PROVIDER=openai 일 때만 필요 (API 키 종량제)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-codex
# OPENAI_BASE_URL=      # Azure/프록시 등 base URL 재정의가 필요할 때만

# content 디렉터리 (초기 리서치 글 ingest 경로)
CONTENT_DIR=../content

# 서버 포트
PORT=8080
