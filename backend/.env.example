# PostgreSQL 연결 문자열 (docker-compose 기준)
DATABASE_URL=postgres://devgraph:devgraph@localhost:5432/devgraph

# 단일 관리자 비밀번호 (로그인에 사용)
ADMIN_PASSWORD=devgraph-admin

# 세션 쿠키 서명 키 (아무 긴 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# 실제 LLM 추출용 OpenAI(Codex) API 키. 없으면 llm 추출이 에러를 반환한다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-codex
# OPENAI_BASE_URL=  # Azure/프록시 등 base URL 재정의가 필요할 때만

# content 디렉터리 (초기 리서치 글 ingest 경로)
CONTENT_DIR=../content

# 서버 포트
PORT=8080
